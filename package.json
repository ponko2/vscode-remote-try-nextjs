{
  "name": "vscode-remote-try-nextjs",
  "version": "0.1.0",
  "dependencies": {
    "@conform-to/react": "^1.17.1",
    "@conform-to/zod": "^1.17.1",
    "@dotenvx/dotenvx": "^1.54.1",
    "@prisma/adapter-better-sqlite3": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "better-sqlite3": "^12.6.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "next": "^16.1.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "remeda": "^2.33.6",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@commitlint/cli": "20.4.4",
    "@commitlint/config-conventional": "20.4.4",
    "@storybook/addon-a11y": "10.2.17",
    "@storybook/addon-docs": "10.2.17",
    "@storybook/addon-links": "10.2.17",
    "@storybook/addon-vitest": "10.2.17",
    "@storybook/nextjs-vite": "10.2.17",
    "@tailwindcss/postcss": "4.2.1",
    "@tsconfig/next": "2.0.6",
    "@tsconfig/strictest": "2.0.8",
    "@types/node": "22.19.15",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.1.4",
    "@vitest/browser": "4.0.18",
    "@vitest/browser-playwright": "4.0.18",
    "@vitest/coverage-v8": "4.0.18",
    "babel-plugin-react-compiler": "1.0.0",
    "globals": "17.4.0",
    "lefthook": "2.1.4",
    "npm-run-all2": "8.0.4",
    "oxfmt": "^0.40.0",
    "oxlint": "^1.55.0",
    "oxlint-tsgolint": "^0.16.0",
    "playwright": "1.58.2",
    "postcss": "8.5.8",
    "prisma": "7.5.0",
    "prisma-case-format": "2.2.1",
    "storybook": "10.2.17",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "4.0.18"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "^24.11.1",
      "onFail": "download"
    }
  },
  "packageManager": "pnpm@10.32.1",
  "private": true,
  "scripts": {
    "build": "next build",
    "build-storybook": "storybook build",
    "dev": "next dev",
    "fix": "run-s fix:oxlint fix:oxfmt fix:prisma-case fix:prisma",
    "fix:oxfmt": "oxfmt",
    "fix:oxlint": "oxlint --fix",
    "fix:prisma": "prisma format",
    "fix:prisma-case": "prisma-case-format --file prisma/schema.prisma",
    "generate": "prisma generate",
    "lint": "run-p --aggregate-output -c -l lint:*",
    "lint:oxfmt": "oxfmt --check",
    "lint:oxlint": "oxlint",
    "setup": "corepack enable pnpm",
    "start": "next start",
    "storybook": "storybook dev -p 6006",
    "test": "vitest --passWithNoTests",
    "test-storybook": "vitest --project=storybook",
    "typecheck": "tsc --noEmit"
  },
  "type": "module"
}
